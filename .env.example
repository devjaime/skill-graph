# Vercel MVP mode: no env vars required. The app uses /lib/mock-data.ts.

# Auth.js. Generate with: npx auth secret
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000

# Optional OAuth providers. Add these in Vercel Project Settings > Environment Variables.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_LINKEDIN_ID=
# AUTH_LINKEDIN_SECRET=

# Optional local SQLite mode for future development. Do not rely on this for Vercel serverless persistence.
# DATABASE_URL=file:./local.db

# Future optional integrations:
# POSTGRES_URL=postgres://user:password@localhost:5432/skillgraph
# OLLAMA_BASE_URL=http://localhost:11434
